{
    "name": "tracknote/api",
    "description": "TrackNote API - Time tracking with notes",
    "type": "project",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "TrackNote\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TrackNote\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test:coverage": "phpunit --colors=always --coverage-html coverage"
    },
    "config": {
        "optimize-autoloader": true
    }
}
