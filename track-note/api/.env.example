# Application
APP_NAME=TrackNote
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

# Database
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=tracknote
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSLMODE=prefer

# Session
SESSION_LIFETIME=7200
SESSION_DOMAIN=
SESSION_SECURE=false

# CORS
CORS_ORIGINS=http://localhost:5173

# Audit
AUDIT_RETENTION_DAYS=365
